  ╰═════════════════⊱`,
          parse_mode: "Markdown"
        });
  
        // Kirim audio
        await ctx.replyWithAudio(audioUrl, {
          title: title,
          performer: "Apocalypse Downloader",
          thumb: thumbnail
        });
  
      } else {
        ctx.reply(`
  ╭═══[ 𝗘𝗥𝗥𝗢𝗥 ]═══⊱
  ┃
  ┃ ❌ Gagal mengunduh musik
  ┃ 𝗜𝗻𝗳𝗼: URL tidak valid
  ╰═════════════════⊱`);
