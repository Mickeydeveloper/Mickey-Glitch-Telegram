bot.command("soundcloud", async (ctx) => {
    const text = ctx.message.text;
    const args = text.split(" ");
  
    if (args.length < 2) {
      return ctx.reply(`
  ╭═══[ 𝗦𝗢𝗨𝗡𝗗𝗖𝗟𝗢𝗨𝗗 ]═══⊱
  ┃
