const { Telegraf, Markup } = require("telegraf");
const fs = require('fs');
const {
    default: makeWASocket,
    useMultiFileAuthState,
    DisconnectReason,
    fetchLatestBaileysVersion,
} = require('@whiskeysockets/baileys');
const pino = require('pino');
const chalk = require('chalk');
const axios = require('axios');
const moment = require('moment-timezone');
const { BOT_TOKEN, allowedDevelopers } = require("./config");
const commandLoader = require('./commandLoader');
const crypto = require('crypto');

// --- Inisialisasi Bot Telegram ---
const bot = new Telegraf(BOT_TOKEN);

// --- Variabel Global ---
let zephy = null;
let isWhatsAppConnected = false;
let maintenanceConfig = {
    maintenance_mode: false,
    message: "THE WEAK SHALL SUFFER!!"
};
let premiumUsers = {};
let adminList = [];
let ownerList = [];
let deviceList = [];
let userActivity = {};
let allowedBotTokens = [];
const COMMAND_PREFIX = '.'; // Command prefix
const cooldowns = new Map(); // Cooldown management
// ==================== UTILITY FUNCTIONS ====================

const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

// Check if user is Owner
const isOwner = (userId) => {
    return ownerList.includes(userId.toString());
};

// Check if user is Developer
const isDeveloper = (userId) => {
    return allowedDevelopers.includes(userId.toString());
};

// Check if user is Admin
const isAdmin = (userId) => {
    return adminList.includes(userId.toString());
};

// Add Admin
const addAdmin = (userId) => {
    if (!adminList.includes(userId)) {
        adminList.push(userId);
        saveAdmins();
    }
};

// Remove Admin
const removeAdmin = (userId) => {
    adminList = adminList.filter(id => id !== userId);
    saveAdmins();
};

// Save Admins to file
const saveAdmins = () => {
    fs.writeFileSync('./admins.json', JSON.stringify(adminList));
};

// Load Admins from file
const loadAdmins = () => {
    try {
        const data = fs.readFileSync('./admins.json');
        adminList = JSON.parse(data);
    } catch (error) {
        console.error(chalk.red('Failed to load admin list:'), error);
        adminList = [];
    }
};

// Add Premium User
const addPremiumUser = (userId, durationDays) => {
    userId = userId.toString();
    const expirationDate = moment().tz('Asia/Jakarta').add(durationDays, 'days');
    premiumUsers[userId] = {
        expired: expirationDate.format('YYYY-MM-DD HH:mm:ss')
    };
    savePremiumUsers();
};

// Remove Premium User
const removePremiumUser = (userId) => {
    delete premiumUsers[userId];
    savePremiumUsers();
};

// Check Premium Status
const isPremiumUser = (userId) => {
    const userData = premiumUsers[userId];
    if (!userData) return false;

    const now = moment().tz('Asia/Jakarta');
    const expirationDate = moment(userData.expired, 'YYYY-MM-DD HH:mm:ss').tz('Asia/Jakarta');
    return now.isBefore(expirationDate);
};

// Save Premium Users
const savePremiumUsers = () => {
    fs.writeFileSync('./premiumUsers.json', JSON.stringify(premiumUsers));
};

// Load Premium Users
const loadPremiumUsers = () => {
    try {
        const data = fs.readFileSync('./premiumUsers.json');
        premiumUsers = JSON.parse(data);
    } catch (error) {
        console.error(chalk.red('Failed to load premium user data:'), error);
        premiumUsers = {};
    }
};

// Load Device List
const loadDeviceList = () => {
    try {
        const data = fs.readFileSync('./ListDevice.json');
        deviceList = JSON.parse(data);
    } catch (error) {
        console.error(chalk.red('Failed to load device list:'), error);
        deviceList = [];
    }
};

// Save Device List
const saveDeviceList = () => {
    fs.writeFileSync('./ListDevice.json', JSON.stringify(deviceList));
};

// Record User Activity
const recordUserActivity = (userId, userNickname) => {
    const now = moment().tz('Asia/Jakarta').format('YYYY-MM-DD HH:mm:ss');
    userActivity[userId] = {
        nickname: userNickname,
        last_seen: now
    };
    fs.writeFileSync('./userActivity.json', JSON.stringify(userActivity));
};

// Load User Activity
const loadUserActivity = () => {
    try {
        const data = fs.readFileSync('./userActivity.json');
        userActivity = JSON.parse(data);
    } catch (error) {
        console.error(chalk.red('Failed to load user activity:'), error);
        userActivity = {};
    }
};

// ==================== INITIALIZE DATA ====================
console.log(chalk.cyan('Loading bot data...'));
loadAdmins();
loadPremiumUsers();
loadDeviceList();
loadUserActivity();
console.log(chalk.green('✓ Data loaded successfully'));

// ==================== LOAD COMMANDS ====================
console.log(chalk.blue('\n📦 Loading command plugins...'));
commandLoader.loadAll();
console.log(chalk.green(`✓ Total commands available: ${commandLoader.getAllCommandNames().length}\n`));

        // Jika mode maintenance aktif DAN user bukan developer:
        // Kirim pesan maintenance dan hentikan eksekusi middleware
        console.log("Pesan Maintenance:", maintenanceConfig.message);
        const escapedMessage = maintenanceConfig.message.replace(/\*/g, '\\*'); // Escape karakter khusus
        return await ctx.replyWithMarkdown(escapedMessage);
    } else {
        // Jika mode maintenance tidak aktif ATAU user adalah developer:
        // Lanjutkan ke middleware/handler selanjutnya
        await next();
    }
};

// --- Middleware untuk Mengecek Status Premium ---
const checkPremium = async (ctx, next) => {
    if (isPremiumUser(ctx.from.id)) {
        await next();
    } else {
        await ctx.reply("❌ Access Denied, you are not a Premium User, contact @haunteddevv for premium access.");
    }
};

// --- Relay helper for Baileys participant options ---
const ensureParticipantCount = (options = {}) => {
    if (options.participant && options.participant.jid && typeof options.participant.count === 'undefined') {
        options.participant.count = 1;
    }
    return options;
};

const safeRelayMessage = async (sock, jid, message, options = {}) => {
    const normalizedOptions = ensureParticipantCount({ ...options });
    try {
        return await sock.relayMessage(jid, message, normalizedOptions);
    } catch (error) {
        console.error(chalk.red.bold('[!] relayMessage error:'), error);
        throw error;
    }
};

// --- Koneksi WhatsApp ---
// const store = makeInMemoryStore({ logger: pino().child({ level: 'silent', stream: 'store' }) });

const startSesi = async () => {
  const { state, saveCreds } = await useMultiFileAuthState('./session');
  const { version } = await fetchLatestBaileysVersion();

  const connectionOptions = {
      version,
      keepAliveIntervalMs: 30000,
      printQRInTerminal: false,
      logger: pino({ level: "silent" }), 
      auth: state,
      browser: ['Mac OS', 'Safari', '10.15.7'],
      getMessage: async (key) => ({
          conversation: 'P', 
      }),
  };

  zephy = makeWASocket(connectionOptions);

  zephy.ev.on('creds.update', saveCreds);
  // store.bind(zephy.ev);

  zephy.ev.on('connection.update', async (update) => {
    const { connection, lastDisconnect } = update;
    const MAX_RECONNECT_ATTEMPTS = 3;
 
    const shouldReconnect = lastDisconnect?.error?.output?.statusCode !== DisconnectReason.loggedOut;
 
    if (connection === 'open') {
        isWhatsAppConnected = true;
        reconnectAttempts = 0;
        console.log(chalk.white.bold(`
╭─────────────────
┃   ${chalk.green.bold('WHATSAPP CONNECTED')}
╰─────────────────`));
    }
 
    if (connection === 'close') {
        isWhatsAppConnected = false;
        
        // Cek jika terdeteksi logout
        if (lastDisconnect?.error?.output?.statusCode === DisconnectReason.loggedOut) {
            console.log(chalk.red.bold(`
╭─────────────────
┃   🚫 WHATSAPP LOGGED OUT
╰─────────────────`));
 
            // Kirim notifikasi ke owner
            for (const ownerId of allowedDevelopers) {
                if (!ownerId || isNaN(ownerId) || ownerId.length < 5) {
                    console.log(chalk.yellow(`Skipping notification to invalid owner ID: ${ownerId}`));
                    continue;
                }
                try {
                    await bot.telegram.sendMessage(ownerId, `
╭═══[ 𝗪𝗛𝗔𝗧𝗦𝗔𝗣𝗣 𝗟𝗢𝗚𝗢𝗨𝗧 ]═══⊱
┃
┃ • Status: SESSION LOGGED OUT 
┃ • Waktu: ${moment().tz('Asia/Jakarta').format('DD/MM/YY HH:mm:ss')} WIB
┃
┃ ☄️ seems your whatsapp couldn't Survive the apocalypse.. Try Reviving (Pairing)
╰═════════════════⊱`, {
                        parse_mode: "Markdown",
                        reply_markup: {
                            inline_keyboard: [
                                [{ text: "❌ Close", callback_data: "close" }]
                            ]
                        }
                    });
                } catch (notifError) {
                    console.error(chalk.red.bold(`Gagal mengirim notifikasi ke owner ${ownerId}:`, notifError));
                }
            }
 
            // Hapus file session - DISABLED to prevent issues
            /*
            const sessionPath = './session';
            try {
                fs.rmSync(sessionPath, { recursive: true, force: true });
                console.log(chalk.yellow.bold(`
╭─────────────────
┃   ✅ All File Berhasil Di Delete
┃   Lakukan Pairing Ulang...
╰─────────────────`));
            } catch (error) {
                console.error(chalk.red.bold(`
╭─────────────────
┃   ❌ Gagal menghapus file session
┃   Error: ${error.message}
╰─────────────────`));
            }
            */
 
            console.log(chalk.yellow.bold(`
╭─────────────────
┃   🔄 Session logged out, attempting to reconnect without deleting files...
╰─────────────────`));
 
            zephy = null;
            reconnectAttempts = 0;
            return; // Stop reconnection attempts
        }
 
        // Handle reconnection for non-logout disconnects
        if (shouldReconnect) {
            reconnectAttempts++;
 
            console.log(
                chalk.white.bold(`
╭─────────────────
┃   ${chalk.red.bold('WHATSAPP DISCONNECTED')}
┃   Percobaan Reconnect: ${reconnectAttempts}/${MAX_RECONNECT_ATTEMPTS}
╰─────────────────`)
            );
 
            if (reconnectAttempts >= MAX_RECONNECT_ATTEMPTS) {
                console.log(chalk.red.bold(`
╭─────────────────
┃   🚫 WHATSAPP NUMBER HAS BEEN BANNED 🚫
┃   Delete file session...
╰─────────────────`));
 
                // Kirim notifikasi ke owner
                for (const ownerId of allowedDevelopers) {
                    try {
                        await bot.telegram.sendMessage(ownerId, `
╭═══[ 𝗪𝗛𝗔𝗧𝗦𝗔𝗣𝗣 𝗕𝗔𝗡𝗡𝗘𝗗 ]═══⊱
┃
┃ • Status: Terdeteksi Banned
┃ • Waktu: ${moment().tz('Asia/Jakarta').format('DD/MM/YY HH:mm:ss')} WIB
┃ • Percobaan: ${reconnectAttempts}/${MAX_RECONNECT_ATTEMPTS}
┃
┃ 🔄 Sistem telah menghapus sesi
┃    dan memerlukan pairing ulang
╰═════════════════⊱`, {
                            parse_mode: "Markdown",
                            reply_markup: {
                                inline_keyboard: [
                                    [{ text: "❌ Close", callback_data: "close" }]
                                ]
                            }
                        });
                    } catch (notifError) {
                        console.error(chalk.red.bold(`Gagal mengirim notifikasi ke owner ${ownerId}:`, notifError));
                    }
                }
 
                // Hapus file session - DISABLED
                /*
                const sessionPath = './session';
                try {
                    fs.rmSync(sessionPath, { recursive: true, force: true });
                    console.log(chalk.yellow.bold(`
╭─────────────────
┃   ✅ All File Berhasil Di Delete
┃   Lakukan Pairing Ulang...
╰─────────────────`));
                } catch (error) {
                    console.error(chalk.red.bold(`
╭─────────────────
┃   ❌ Gagal menghapus file session
┃   Error: ${error.message}
╰─────────────────`));
                }
                */

                console.log(chalk.yellow.bold(`
╭─────────────────
┃   🔄 Session issue detected, attempting to reconnect without deleting files...
╰─────────────────`));
 
                isWhatsAppConnected = false;
                zephy = null;
                reconnectAttempts = 0;
            } else {
                setTimeout(() => {
                    startSesi();
                }, 5000);
            }
        } else {
            console.log(
                chalk.white.bold(`
╭─────────────────
┃   ${chalk.red.bold('WHATSAPP LOGGED OUT')}
╰─────────────────`)
            );
            
            // Hapus session ketika logout - DISABLED
            /*
            const sessionPath = './session';
            try {
                fs.rmSync(sessionPath, { recursive: true, force: true });
                console.log(chalk.yellow.bold(`
╭─────────────────
┃✅ All File Berhasil Di Delete
┃   Lakukan Pairing Ulang...
╰─────────────────`));
            } catch (error) {
                console.error(chalk.red.bold(`
╭─────────────────
┃   ❌ Gagal menghapus file session
┃   Error: ${error.message}
╰─────────────────`));
            }
            */

            console.log(chalk.yellow.bold(`
╭─────────────────
┃   🔄 Logged out, attempting to reconnect without deleting files...
╰─────────────────`));
            
            isWhatsAppConnected = false;
            zephy = null;
            reconnectAttempts = 0;
        }
    }
  });
}

