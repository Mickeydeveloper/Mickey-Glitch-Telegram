  ┃ 𝗖𝗼𝗻𝘁𝗼𝗵:
  ┃ /soundcloud https://soundcloud.com/xxx
  ╰═════════════════════⊱`);
    }
  
    const url = args[1];
    const apiUrl = `https://api.betabotz.eu.org/api/download/soundcloud?url=${url}&apikey=Btz-kp72a`;
  
    await ctx.reply(`
  ╭═══[ 𝗣𝗥𝗢𝗖𝗘𝗦𝗦𝗜𝗡𝗚 𝗔𝗨𝗗𝗜𝗢 ]═══⊱
   ▏ﮩ٨ـﮩﮩ٨ـ♡ﮩ٨ـﮩﮩ٨ـ▏
  ┃ ⏳ 𝙎𝙚𝙖𝙧𝙘𝙝𝙞𝙣𝙜 𝙛𝙤𝙧 𝙢𝙪𝙨𝙞𝙘
  ┃ 𝗨𝗿𝗹: ${url}
  ╰═════════════════⊱`);
  
    try {
      const response = await axios.get(apiUrl);
      const data = response.data;
  
      if (data.status && data.result) {
        const audioUrl = data.result.url;
        const title = data.result.title;
        const thumbnail = data.result.thumbnail || "https://cdn.anomaki.web.id/file/1739523183904.jpeg";
  
        // Kirim thumbnail dengan audio
        await ctx.replyWithPhoto(thumbnail, {
