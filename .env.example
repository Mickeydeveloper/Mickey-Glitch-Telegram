# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Allowed Developers (comma-separated user IDs)
ALLOWED_DEVELOPERS=123456789

# Bot Settings
BOT_PREFIX=.
BOT_TIMEZONE=Asia/Jakarta
BOT_VERSION=5.0.0

# WhatsApp Settings
WHATSAPP_AUTO_CONNECT=true
WHATSAPP_SESSION_PATH=./session

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# Command Cooldown
COMMAND_COOLDOWN_MS=3000

# Debug Mode
DEBUG=false

# Logging
LOG_FILE_ENABLED=true
LOG_DIR=./logs

# Premium Features
PREMIUM_ENABLED=true

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Bot is under maintenance. Please try again later.

# Additional Commands Path
COMMANDS_PATH=./commands
